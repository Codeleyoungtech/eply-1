<%
// Helper to format Unix timestamps
const fmt = (ts) => ts ? new Date(ts * 1000).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
const statusClass = waStatus === 'connected' ? 'connected' : waStatus === 'connecting' ? 'connecting' : 'disconnected';
const statusLabel = waStatus === 'connected' ? '● Connected' : waStatus === 'connecting' ? '● Connecting' : '● Disconnected';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
<div class="shell">
  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="wordmark"><span>E</span>PLY</div>
      <div class="tagline">Your AI Self on WhatsApp</div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Overview</div>
      <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>"><span class="icon">⚡</span> <span>Dashboard</span></a>
      <a href="/qr" class="nav-link <%= currentPath === '/qr' ? 'active' : '' %>"><span class="icon">📱</span> <span>Connect WA</span></a>
    </div>
    <div class="nav-section">
      <div class="nav-label">Identity</div>
      <a href="/identity" class="nav-link <%= currentPath === '/identity' ? 'active' : '' %>"><span class="icon">✍️</span> <span>Identity</span></a>
      <a href="/vip" class="nav-link <%= currentPath === '/vip' ? 'active' : '' %>"><span class="icon">👑</span> <span>VIP List</span></a>
    </div>
    <div class="nav-section">
      <div class="nav-label">Activity</div>
      <a href="/flagged" class="nav-link <%= currentPath === '/flagged' ? 'active' : '' %>"><span class="icon">⚠️</span> <span>Flagged</span></a>
      <a href="/digest" class="nav-link <%= currentPath === '/digest' ? 'active' : '' %>"><span class="icon">☀️</span> <span>Digest</span></a>
      <a href="/chats" class="nav-link <%= currentPath.startsWith('/chats') ? 'active' : '' %>"><span class="icon">💬</span> <span>Chats</span></a>
      <a href="/memory" class="nav-link <%= currentPath === '/memory' ? 'active' : '' %>"><span class="icon">🧠</span> <span>Memory</span></a>
    </div>
    <div class="nav-section">
      <div class="nav-label">System</div>
      <a href="/scheduler" class="nav-link <%= currentPath === '/scheduler' ? 'active' : '' %>"><span class="icon">🕐</span> <span>Scheduler</span></a>
      <a href="/settings" class="nav-link <%= currentPath === '/settings' ? 'active' : '' %>"><span class="icon">⚙️</span> <span>Settings</span></a>
      <a href="/logs" class="nav-link <%= currentPath === '/logs' ? 'active' : '' %>"><span class="icon">📡</span> <span>Live Logs</span></a>
    </div>
    <div class="sidebar-footer">
      <span class="status-badge <%= statusClass %>"><%= statusLabel %></span>
      <a href="/logout" class="btn btn-ghost btn-sm">Sign out</a>
    </div>
  </nav>
  <!-- Main -->
  <main class="main">
    <div class="page">
      <%- body %>
    </div>
  </main>
</div>
</body>
</html>
