<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/style.css" />
</head>

<body>
    <div class="shell">
        <%- include('_sidebar') %>
            <main class="main">
                <div class="page">
                    <div class="page-header">
                        <div style="display:flex;align-items:center;gap:12px">
                            <a href="/chats" class="btn btn-ghost btn-sm">← Back</a>
                            <div>
                                <div class="page-title">
                                    <%= jid.split('@')[0] %>
                                </div>
                                <div class="page-sub">
                                    <%= jid %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="thread">
                            <% thread.forEach(m=> { %>
                                <div
                                    style="display:flex;flex-direction:column;align-items:<%= m.direction === 'out' ? 'flex-end' : 'flex-start' %>">
                                    <div class="bubble bubble-<%= m.direction === 'out' ? 'out' : 'in' %>">
                                        <%= m.content %>
                                            <div class="bubble-meta">
                                                <%= new
                                                    Date(m.timestamp*1000).toLocaleString('en-GB',{hour:'2-digit',minute:'2-digit',day:'numeric',month:'short'})
                                                    %>
                                                    <% if (m.llm_used) { %><span class="badge badge-<%= m.llm_used %>"
                                                            style="margin-left:4px">
                                                            <%= m.llm_used %>
                                                        </span>
                                                        <% } %>
                                            </div>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                    </div>
                </div>
            </main>
    </div>
</body>

</html>