<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/style.css" />
</head>

<body>
    <div class="shell">
        <%- include('_sidebar') %>
            <main class="main">
                <div class="page">
                    <div class="page-header">
                        <div class="page-title">💬 Chat Monitor</div>
                        <div class="page-sub">Every conversation EPLY has handled — full thread view</div>
                    </div>
                    <% if (!chats.length) { %>
                        <div class="card" style="text-align:center;padding:48px">
                            <div style="font-size:48px;margin-bottom:12px">💬</div>
                            <div style="font-size:17px;font-weight:700">No chats yet</div>
                            <p style="color:var(--muted);margin-top:6px">Chats will appear here once EPLY starts
                                handling messages.</p>
                        </div>
                        <% } else { %>
                            <div class="card">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Contact</th>
                                            <th>JID</th>
                                            <th>Total Msgs</th>
                                            <th>Replied</th>
                                            <th>Last Active</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% chats.forEach(c=> { %>
                                            <tr>
                                                <td><strong>
                                                        <%= c.contact_name || '—' %>
                                                    </strong></td>
                                                <td style="font-family:monospace;font-size:12px;color:var(--muted)">
                                                    <%= c.jid.split('@')[0] %>
                                                </td>
                                                <td>
                                                    <%= c.total %>
                                                </td>
                                                <td>
                                                    <%= c.replied %>
                                                </td>
                                                <td style="color:var(--muted);white-space:nowrap">
                                                    <%= new
                                                        Date(c.last_ts*1000).toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})
                                                        %>
                                                </td>
                                                <td><a href="/chats/<%= encodeURIComponent(c.jid) %>"
                                                        class="btn btn-ghost btn-sm">View Thread</a></td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                </div>
            </main>
    </div>
</body>

</html>