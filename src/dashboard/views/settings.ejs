<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/style.css" />
</head>

<body>
    <div class="shell">
        <%- include('_sidebar') %>
            <main class="main">
                <div class="page">
                    <div class="page-header">
                        <div class="page-title">⚙️ Settings</div>
                        <div class="page-sub">Model defaults, notification method, urgency keywords, feature toggles
                        </div>
                    </div>
                    <% if (saved) { %>
                        <div class="alert alert-success">✅ Settings saved</div>
                        <% } %>
                            <form method="POST" action="/settings">
                                <div class="grid-2" style="margin-bottom:16px">
                                    <div class="card">
                                        <div class="card-title">LLM & Routing</div>
                                        <div class="form-group">
                                            <label class="form-label">Default Model</label>
                                            <select class="form-select" name="default_model">
                                                <% ['auto','groq','gemini','claude'].forEach(m=> { %>
                                                    <option value="<%= m %>" <%=settings.default_model===m ? 'selected'
                                                        : '' %>><%= m %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Log Level</label>
                                            <select class="form-select" name="log_level">
                                                <% ['debug','info','warn','error'].forEach(l=> { %>
                                                    <option value="<%= l %>" <%=settings.log_level===l ? 'selected' : ''
                                                        %>><%= l %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Daily Reply Limit</label>
                                            <input class="form-input" name="daily_reply_limit"
                                                value="<%= settings.daily_reply_limit || '80' %>" placeholder="80" />
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Daily Estimated Token Limit</label>
                                            <input class="form-input" name="daily_estimated_token_limit"
                                                value="<%= settings.daily_estimated_token_limit || '12000' %>" placeholder="12000" />
                                        </div>
                                    </div>
                                    <div class="card">
                                        <div class="card-title">Notifications</div>
                                        <div class="form-group">
                                            <label class="form-label">Notify Method</label>
                                            <select class="form-select" name="notify_method">
                                                <% ['self_chat','secondary_number','telegram','dashboard'].forEach(m=> {
                                                    %>
                                                    <option value="<%= m %>" <%=settings.notify_method===m ? 'selected'
                                                        : '' %>><%= m %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Digest Time (HH:MM)</label>
                                            <input class="form-input" name="digest_time"
                                                value="<%= settings.digest_time || '07:00' %>" placeholder="07:00" />
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Digest Timezone</label>
                                            <input class="form-input" name="digest_timezone"
                                                value="<%= settings.digest_timezone || 'Africa/Johannesburg' %>"
                                                placeholder="Africa/Johannesburg" />
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Store Group Messages</label>
                                            <select class="form-select" name="store_group_messages">
                                                <% ['false','true'].forEach(v=> { %>
                                                    <option value="<%= v %>" <%=settings.store_group_messages===v ? 'selected' : '' %>><%= v %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Reply Style Guard</label>
                                            <select class="form-select" name="reply_style_guard">
                                                <% ['true','false'].forEach(v=> { %>
                                                    <option value="<%= v %>" <%=settings.reply_style_guard===v ? 'selected' : '' %>><%= v %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="card" style="margin-bottom:16px">
                                    <div class="card-title">Urgency Keywords</div>
                                    <div class="form-group">
                                        <div class="form-hint" style="margin-bottom:8px">JSON array of keywords that
                                            trigger an immediate ping (case-insensitive)</div>
                                        <textarea class="form-textarea" name="urgency_keywords"
                                            rows="3"><%= settings.urgency_keywords %></textarea>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary">Save Settings</button>
                            </form>
                </div>
            </main>
    </div>
</body>

</html>
