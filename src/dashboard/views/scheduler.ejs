<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/style.css" />
</head>

<body>
    <div class="shell">
        <%- include('_sidebar') %>
            <main class="main">
                <div class="page">
                    <div class="page-header">
                        <div class="page-title">🕐 Scheduler</div>
                        <div class="page-sub">Cron jobs — digest schedule, reminders, recurring messages</div>
                    </div>
                    <div class="grid-2" style="margin-bottom:20px">
                        <div class="card">
                            <div class="card-title">Create Job</div>
                            <form method="POST" action="/scheduler/create"
                                style="display:flex;flex-direction:column;gap:10px">
                                <div class="form-group" style="margin-bottom:0"><label class="form-label">Job
                                        Name</label><input class="form-input" name="name" placeholder="Daily digest"
                                        required /></div>
                                <div class="form-group" style="margin-bottom:0"><label class="form-label">Cron
                                        Expression</label><input class="form-input" name="cron_expr"
                                        placeholder="0 7 * * * (07:00 daily)" /></div>
                                <button type="submit" class="btn btn-primary">Create Job</button>
                            </form>
                        </div>
                        <div class="card">
                            <div class="card-title">Active Jobs (<%= jobs.length %>)</div>
                            <% if (!jobs.length) { %>
                                <p style="color:var(--muted);font-size:13px">No custom jobs. The daily digest cron runs
                                    automatically from your settings.</p>
                                <% } else { %>
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Cron</th>
                                                <th>Last Run</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% jobs.forEach(j=> { %>
                                                <tr>
                                                    <td>
                                                        <%= j.name %>
                                                    </td>
                                                    <td style="font-family:monospace;font-size:12px">
                                                        <%= j.cron_expr || '—' %>
                                                    </td>
                                                    <td style="color:var(--muted)">
                                                        <%= j.last_run ? new
                                                            Date(j.last_run*1000).toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})
                                                            : 'Never' %>
                                                    </td>
                                                    <td>
                                                        <form method="POST" action="/scheduler/<%= j.id %>/delete">
                                                            <button class="btn btn-danger btn-sm">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                    <% } %>
                        </div>
                    </div>
                </div>
            </main>
    </div>
</body>

</html>