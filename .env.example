# ─────────────────────────────────────────────────────
#  EPLY — Environment Variables
#  Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────

# ── LLM API Keys (get at least ONE) ───────────────────
# Groq (free tier, fastest): https://console.groq.com
GROQ_API_KEY=

# Gemini (free tier, multimodal): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude (best reasoning, paid): https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Your WhatsApp Number (digits only, no + or spaces) ──
# Example: 27821234567 for +27 82 123 4567
ADMIN_NUMBER=2348119729920

# ── Dashboard ─────────────────────────────────────────
DASHBOARD_PASSWORD=change_this_to_something_strong
DASHBOARD_PORT=3000

# ── Redis (Optional — used for digest queue retries) ──
# Railway: add a Redis service and it auto-injects this
# REDIS_URL=redis://localhost:6379

# ── Database path ─────────────────────────────────────
# LOCAL:   DB_PATH=./eply.db
# RAILWAY: DB_PATH=/data/eply.db  (requires a Volume)
DB_PATH=./eply.db

# ── WhatsApp Auth Dir ─────────────────────────────────
# LOCAL:   AUTH_DIR=./auth_info_baileys
# RAILWAY: AUTH_DIR=/data/auth_info_baileys  (requires same Volume)
AUTH_DIR=./auth_info_baileys

# ── Daily Digest ──────────────────────────────────────
DIGEST_TIME=07:00
DIGEST_TIMEZONE=Africa/Johannesburg

# ── Notifications ─────────────────────────────────────
# Options: self_chat | secondary_number | telegram | dashboard
NOTIFY_METHOD=self_chat
NOTIFY_NUMBER=

# ── LLM Routing ───────────────────────────────────────
# auto = smart routing (recommended)
# groq | gemini | claude = force a specific model
DEFAULT_MODEL=auto

# ── Auto-reply master switch ──────────────────────────
# Set to true to enable. Use !off command to disable live.
AUTO_REPLY_ENABLED=true

# ── Runtime ───────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
